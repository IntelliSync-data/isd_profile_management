<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Profile Management Tree View -->
    <record id="view_profile_management_tree" model="ir.ui.view">
        <field name="name">profile.management.tree</field>
        <field name="model">profile.management</field>
        <field name="arch" type="xml">
            <list string="Profiles" decoration-success="state=='active'" decoration-muted="state=='inactive'">
                <field name="name"/>
                <field name="description"/>
                <field name="total_steps"/>
                <field name="total_cost" widget="monetary"/>
                <field name="assigned_user_count"/>
                <field name="state" widget="badge" decoration-success="state=='active'" decoration-danger="state=='inactive'"/>
                <field name="create_uid"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Profile Management Form View -->
    <record id="view_profile_management_form" model="ir.ui.view">
        <field name="name">profile.management.form</field>
        <field name="model">profile.management</field>
        <field name="arch" type="xml">
            <form string="Profile">
                <header>
                    <button name="action_activate" string="Activate" type="object" 
                            class="btn-primary" invisible="state == 'active'"/>
                    <button name="action_deactivate" string="Deactivate" type="object" 
                            invisible="state != 'active'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,inactive"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_users" type="object" class="oe_stat_button" icon="fa-users">
                            <field name="assigned_user_count" widget="statinfo" string="Users"/>
                        </button>
                        <button name="action_view_steps" type="object" class="oe_stat_button" icon="fa-tasks">
                            <field name="total_steps" widget="statinfo" string="Steps"/>
                        </button>
                        <button name="action_view_api_doc" type="object" class="oe_stat_button" icon="fa-code" string="View API"/>
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Profile Name..."/>
                        </h1>
                    </div>
                    
                    <group>
                        <group>
                            <field name="description" placeholder="Profile description..."/>
                        </group>
                        <group>
                            <field name="package_cost" widget="monetary"/>
                            <field name="total_cost" widget="monetary"/>
                            <field name="is_advanced"/>
                            <field name="is_auto_complete"/>
                            <field name="create_uid"/>
                            <field name="create_date"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Steps" name="steps">
                            <field name="step_ids">
                                <list editable="bottom" decoration-success="state=='active'" decoration-muted="state=='inactive'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="cost" widget="monetary"/>
                                    <field name="duration_days"/>
                                    <field name="is_mandatory"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Assigned Users" name="users">
                            <field name="user_profile_ids">
                                <list>
                                    <field name="user_id"/>
                                    <field name="state" widget="badge"/>
                                    <field name="progress_percentage" widget="progressbar"/>
                                    <field name="start_date"/>
                                    <field name="assigned_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Profile Management Kanban View -->
    <record id="view_profile_management_kanban" model="ir.ui.view">
        <field name="name">profile.management.kanban</field>
        <field name="model">profile.management</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="description"/>
                <field name="total_steps"/>
                <field name="total_cost"/>
                <field name="total_cost_vnd"/>
                <field name="assigned_user_count"/>
                <field name="state"/>
                <field name="create_date"/>
                <field name="create_uid"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click" style="margin: 8px; border: 2px solid #875A7B; border-radius: 12px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); min-width: 350px; width: 350px;">
                            <div class="oe_kanban_content" style="padding: 16px;">
                                <!-- Header with title and status -->
                                <div class="o_kanban_record_top mb-2">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title" style="color: #875A7B; font-size: 18px;">
                                                <field name="name"/>
                                            </strong>
                                        </div>
                                        <div>
                                            <span t-if="record.state.raw_value == 'active'" class="badge badge-pill" style="background: linear-gradient(135deg, #28a745, #20c997); color: white; font-size: 12px; font-weight: bold; padding: 6px 12px; box-shadow: 0 2px 4px rgba(40, 167, 69, 0.3); border: none; margin-left: 4px;">
                                                ✓ <field name="state"/>
                                            </span>
                                            <span t-elif="record.state.raw_value == 'inactive'" class="badge badge-pill" style="background: linear-gradient(135deg, #6c757d, #adb5bd); color: white; font-size: 12px; font-weight: bold; padding: 6px 12px; box-shadow: 0 2px 4px rgba(108, 117, 125, 0.3); border: none; margin-left: 4px;">
                                                ⏸ <field name="state"/>
                                            </span>
                                            <span t-else="" class="badge badge-pill" style="background: linear-gradient(135deg, #ffc107, #fd7e14); color: #212529; font-size: 12px; font-weight: bold; padding: 6px 12px; box-shadow: 0 2px 4px rgba(255, 193, 7, 0.3); border: none; margin-left: 4px;">
                                                ⚠ <field name="state"/>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Description -->
                                <div class="o_kanban_record_body mb-3">
                                    <div style="color: #666; font-size: 14px; line-height: 1.4;">
                                        <field name="description"/>
                                    </div>
                                </div>
                                
                                <!-- Stats Row -->
                                <div class="row mb-2" style="margin-left: -4px; margin-right: -4px;">
                                    <div class="col-4 text-center" style="padding-left: 4px; padding-right: 4px;">
                                        <div style="background: linear-gradient(135deg, #875A7B, #9d6e91); border-radius: 10px; padding: 10px; box-shadow: 0 2px 6px rgba(135, 90, 123, 0.2); height: 60px; display: flex; flex-direction: column; justify-content: center;">
                                            <div style="font-size: 18px; font-weight: bold; color: white;">
                                                <field name="total_steps"/>
                                            </div>
                                            <div style="font-size: 11px; color: rgba(255,255,255,0.9); font-weight: 500;">Steps</div>
                                        </div>
                                    </div>
                                    <div class="col-4 text-center" style="padding-left: 4px; padding-right: 4px;">
                                        <div style="background: linear-gradient(135deg, #28a745, #20c997); border-radius: 10px; padding: 10px; box-shadow: 0 2px 6px rgba(40, 167, 69, 0.2); height: 60px; display: flex; flex-direction: column; justify-content: center;">
                                            <div style="font-size: 16px; font-weight: bold; color: white; line-height: 1.2;">
                                                <field name="total_cost_vnd"/>
                                            </div>
                                            <div style="font-size: 11px; color: rgba(255,255,255,0.9); font-weight: 500;">Cost</div>
                                        </div>
                                    </div>
                                    <div class="col-4 text-center" style="padding-left: 4px; padding-right: 4px;">
                                        <div style="background: linear-gradient(135deg, #17a2b8, #20a9cc); border-radius: 10px; padding: 10px; box-shadow: 0 2px 6px rgba(23, 162, 184, 0.2); height: 60px; display: flex; flex-direction: column; justify-content: center;">
                                            <div style="font-size: 18px; font-weight: bold; color: white;">
                                                <field name="assigned_user_count"/>
                                            </div>
                                            <div style="font-size: 11px; color: rgba(255,255,255,0.9); font-weight: 500;">Users</div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Footer -->
                                <div class="o_kanban_record_bottom mt-3 pt-2" style="border-top: 1px solid #eee;">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div style="font-size: 12px; color: #999;">
                                            Created by <field name="create_uid"/>
                                        </div>
                                        <div style="font-size: 12px; color: #999;">
                                            <field name="create_date" widget="date"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Profile Management Search View -->
    <record id="view_profile_management_search" model="ir.ui.view">
        <field name="name">profile.management.search</field>
        <field name="model">profile.management</field>
        <field name="arch" type="xml">
            <search string="Search Profiles">
                <field name="name" string="Profile" filter_domain="[('name','ilike',self)]"/>
                <field name="description"/>
                <separator/>
                <filter string="Active" name="active" domain="[('state','=','active')]"/>
                <filter string="Inactive" name="inactive" domain="[('state','=','inactive')]"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Created By" name="group_create_uid" context="{'group_by':'create_uid'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Profile Management Action -->
    <record id="action_profile_management" model="ir.actions.act_window">
        <field name="name">Package Configuration</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">profile.management</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_profile_management_search"/>
        <field name="context">{}</field>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No packages configured yet!
            </p>
            <p>
                Create your first service package to get started.
            </p>
        </field>
    </record>

    <!-- Specify kanban (card) view for Configuration → Profiles -->
    <record id="action_profile_management_view_kanban" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_profile_management_kanban"/>
        <field name="act_window_id" ref="action_profile_management"/>
    </record>

    <!-- Specify list view for Configuration → Profiles -->
    <record id="action_profile_management_view_list" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_profile_management_tree"/>
        <field name="act_window_id" ref="action_profile_management"/>
    </record>

    <!-- Specify clean form view for Configuration → Profiles -->
    <record id="action_profile_management_view_form" model="ir.actions.act_window.view">
        <field name="sequence">3</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_profile_management_form"/>
        <field name="act_window_id" ref="action_profile_management"/>
    </record>
</odoo>