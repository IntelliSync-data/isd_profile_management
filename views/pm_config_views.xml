<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_pm" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pm_config</field>
        <field name="model">res.config.settings</field>
        <!-- <field name="priority" eval="100"/> -->
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
            <!-- <form string="PM Settings"> -->
                <app data-string="Profile Management"
                    string="Profile Management"
                    name="isd_profile_management">
                    <div class="app_settings_block" data-string="Payment Configuration" string="Payment Configuration" data-key="payment_config" groups="base.group_user">
                        <h2>Payment Configuration</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_payment_method_ids"/>
                                    <div class="text-muted">
                                        Select payment methods configured in ISD Payment module
                                    </div>
                                    <field name="pm_payment_method_ids" widget="many2many_tags" class="mt-2"/>
                                </div>
                            </div>
                        </div>

                        <h2>Legacy Sepay Payment (Deprecated)</h2>
                        <group invisible="1">
                        <div class="alert alert-warning" role="alert">
                            <strong>Note:</strong> These fields are deprecated. Please use Payment Method above instead.
                        </div>
                        <div class="row mt16 o_settings_container" id="profile_management">
                            <div id="use_collaborative_pad" class="col-12 col-lg-6 o_setting_box" title="">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane" name="profile_management_pm_sepay_host_right_pane">
                                    <label for="pm_sepay_host"/><br/>
                                    <field name="pm_sepay_host"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_sepay_qr_host"/><br/>
                                    <field name="pm_sepay_qr_host"/>
                                </div>                                    
                            </div>                            
                        </div>
                        <div class="row mt16 o_settings_container" id="profile_management">
                            <div id="use_collaborative_pad" class="col-12 col-lg-6 o_setting_box" title="">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane" name="profile_management_pm_sepay_host_right_pane">
                                    <label for="pm_sepay_acc_number"/><br/>
                                    <field name="pm_sepay_acc_number"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_sepay_acc_bank"/><br/>
                                    <field name="pm_sepay_acc_bank"/>
                                </div>                                    
                            </div>                            
                        </div>
                        <div class="row mt16 o_settings_container" id="profile_management">
                            <div id="use_collaborative_pad" class="col-12 col-lg-6 o_setting_box" title="">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane" name="profile_management_pm_sepay_host_right_pane">
                                    <label for="pm_sepay_api_token"/><br/>
                                    <field name="pm_sepay_api_token"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_sepay_prefix_transaction_id"/><br/>
                                    <field name="pm_sepay_prefix_transaction_id"/>
                                </div>                                    
                            </div>
                        </div>
                        </group>

                        <h2>VTC Pay Payment</h2>
                        <div class="row mt16 o_settings_container" id="profile_management">
                            <div id="use_collaborative_pad" class="col-12 col-lg-6 o_setting_box" title="">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane" name="profile_management_pm_sepay_host_right_pane">
                                    <label for="pm_vtcpay_host"/><br/>
                                    <field name="pm_vtcpay_host"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_vtcpay_key_sign"/><br/>
                                    <field name="pm_vtcpay_key_sign"/>
                                </div>                                    
                            </div>                            
                        </div>
                        <div class="row mt16 o_settings_container" id="profile_management">
                            <div id="use_collaborative_pad" class="col-12 col-lg-6 o_setting_box" title="">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane" name="profile_management_pm_sepay_host_right_pane">
                                    <label for="pm_vtcpay_website_id"/><br/>
                                    <field name="pm_vtcpay_website_id"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_vtcpay_security_code"/><br/>
                                    <field name="pm_vtcpay_security_code"/>
                                </div>                                    
                            </div>                            
                        </div>
                        <div class="row mt16 o_settings_container" id="profile_management">
                            <div id="use_collaborative_pad" class="col-12 col-lg-6 o_setting_box" title="">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane" name="profile_management_pm_sepay_host_right_pane">
                                    <label for="pm_vtcpay_payment_type"/><br/>
                                    <field name="pm_vtcpay_payment_type"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_vtcpay_receiver_account"/><br/>
                                    <field name="pm_vtcpay_receiver_account"/>
                                </div>                                    
                            </div>                            
                        </div>

                        <h2>Paypal Payment</h2>
                        <div class="row mt16 o_settings_container" id="profile_management">
                            <div id="use_collaborative_pad" class="col-12 col-lg-6 o_setting_box" title="">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane" name="profile_management_pm_sepay_host_right_pane">
                                    <label for="pm_paypal_host"/><br/>
                                    <field name="pm_paypal_host"/>
                                </div>
                            </div>                     
                        </div>
                        <div class="row mt16 o_settings_container" id="profile_management">
                            <div id="use_collaborative_pad" class="col-12 col-lg-6 o_setting_box" title="">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane" name="profile_management_pm_sepay_host_right_pane">
                                    <label for="pm_paypal_client_id"/><br/>
                                    <field name="pm_paypal_client_id"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_paypal_client_secret"/><br/>
                                    <field name="pm_paypal_client_secret"/>
                                </div>                                    
                            </div>                            
                        </div>
                        <div class="row mt16 o_settings_container" id="profile_management">
                            <div id="use_collaborative_pad" class="col-12 col-lg-6 o_setting_box" title="">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane" name="profile_management_pm_sepay_host_right_pane">
                                    <label for="pm_paypal_mode"/><br/>
                                    <field name="pm_paypal_mode"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_paypal_usd_exchange_rate"/><br/>
                                    <field name="pm_paypal_usd_exchange_rate"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="app_settings_block" data-string="General" string="General" data-key="general" groups="base.group_user">
                        <h2>General</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"></div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_currency"/>
                                    <div class="text-muted">Currency symbol used for payment display</div>
                                    <field name="pm_currency" class="mt-2"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="app_settings_block" data-string="Email Templates" string="Email Templates" data-key="email_templates" groups="base.group_user">
                        <h2>Email Notification Templates</h2>
                        <div class="alert alert-info" role="alert">
                            <strong>Note:</strong> Configure email templates for customer notifications. Assignment emails to internal users are sent separately.
                        </div>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_email_order_template_id"/>
                                    <div class="text-muted">
                                        Email sent to customer when a new package order is created
                                    </div>
                                    <field name="pm_email_order_template_id" class="mt-2"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_email_payment_template_id"/>
                                    <div class="text-muted">
                                        Email sent to customer when payment is confirmed
                                    </div>
                                    <field name="pm_email_payment_template_id" class="mt-2"/>
                                </div>
                            </div>
                        </div>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="pm_send_assignment_emails"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="pm_send_assignment_emails"/>
                                    <div class="text-muted">
                                        Enable to send assignment/activity emails to end users. If disabled, only internal users receive these notifications.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </app>
            <!-- </form> -->
            </xpath>
        </field>
    </record>

    <record id="action_pm_settings_config" model="ir.actions.act_window">
        <field name="name">PM Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'isd_profile_management'}</field>
    </record>
</odoo>
