<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Manager Dashboard with Tabs -->
    <record id="view_manager_dashboard_form" model="ir.ui.view">
        <field name="name">manager.dashboard.form</field>
        <field name="model">profile.management</field>
        <field name="arch" type="xml">
            <form string="Manager Dashboard" create="false" edit="false">
                <sheet>
                    <div >
                    </div>
                    
                </sheet>
            </form>
        </field>
    </record>

    <!-- Clean Profile Management Form (No Chatter) -->
    <record id="view_profile_management_clean_form" model="ir.ui.view">
        <field name="name">profile.management.clean.form</field>
        <field name="model">profile.management</field>
        <field name="arch" type="xml">
            <form string="Package Configuration">
                <sheet>
                    <div >
                    </div>
                    
                    <group>
                        <group>
                            <field name="description" />
                            <field name="total_steps" readonly="1"/>
                            <field name="total_cost_display" readonly="1"/>
                        </group>
                        <group>
                            <field name="assigned_user_count" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                            <field name="create_uid" readonly="1"/>
                        </group>
                    </group>

                </sheet>
                <!-- NO CHATTER HERE -->
            </form>
        </field>
    </record>

    <!-- Manager Dashboard Action -->
    <record id="action_manager_dashboard_new" model="ir.actions.act_window">
        <field name="name">Manager Dashboard</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">profile.management</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_manager_dashboard_form"/>
        <field name="target">current</field>
        <field name="context">{'create': False, 'edit': False}</field>
        <field name="help" type="html">
            <p >
                Welcome to the Manager Dashboard!
            </p>
            <p>
                Use the tabs above to manage items, packages, and user assignments.
            </p>
        </field>
    </record>

</odoo>