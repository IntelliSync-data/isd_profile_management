<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Profile Management Categories -->
        <record id="module_category_profile_management" model="ir.module.category">
            <field name="name">Profile Management</field>
            <field name="description">Manage user profiles and progress tracking</field>
            <field name="sequence">25</field>
        </record>

        <!-- Profile Student Only Group (for menu visibility) -->
        <record id="group_profile_student_only" model="res.groups">
            <field name="name">Student Only</field>
            <field name="category_id" ref="module_category_profile_management"/>
            <field name="comment">Group for student-only menus (excludes managers)</field>
        </record>

        <!-- Profile Manager Group -->
        <record id="group_profile_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_profile_management"/>
            <field name="comment">Managers can create profiles, assign users, and confirm payments</field>
        </record>


        <!-- Record Rules for Managers (Full Access) -->
        <record id="rule_profile_manager" model="ir.rule">
            <field name="name">Manager: All Profiles</field>
            <field name="model_id" ref="model_profile_management"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_profile_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_step_manager" model="ir.rule">
            <field name="name">Manager: All Steps</field>
            <field name="model_id" ref="model_profile_step"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_profile_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_user_profile_manager" model="ir.rule">
            <field name="name">Manager: All User Profiles</field>
            <field name="model_id" ref="model_user_profile"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_profile_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_user_step_manager" model="ir.rule">
            <field name="name">Manager: All User Steps</field>
            <field name="model_id" ref="model_user_step"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_profile_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_payment_manager" model="ir.rule">
            <field name="name">Manager: All Payments</field>
            <field name="model_id" ref="model_profile_payment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_profile_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>


        <!-- Record Rules for Student Only Group -->
        <record id="rule_user_profile_student_only" model="ir.rule">
            <field name="name">Student Only: Own User Profiles</field>
            <field name="model_id" ref="model_user_profile"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_profile_student_only'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_user_step_student_only" model="ir.rule">
            <field name="name">Student Only: Own User Steps</field>
            <field name="model_id" ref="model_user_step"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_profile_student_only'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_payment_student_only" model="ir.rule">
            <field name="name">Student Only: Own Payments</field>
            <field name="model_id" ref="model_profile_payment"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_profile_student_only'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_profile_student_only_read" model="ir.rule">
            <field name="name">Student Only: Read Active Profiles</field>
            <field name="model_id" ref="model_profile_management"/>
            <field name="domain_force">[('state', '=', 'active')]</field>
            <field name="groups" eval="[(4, ref('group_profile_student_only'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_step_student_only_read" model="ir.rule">
            <field name="name">Student Only: All Steps Access</field>
            <field name="model_id" ref="model_profile_step"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_profile_student_only'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>