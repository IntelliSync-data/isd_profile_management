<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_step_selection_wizard" model="ir.ui.view">
        <field name="name">step.selection.wizard.form</field>
        <field name="model">step.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Your Services">
                <group>
                    <field name="profile_id" invisible="1"/>
                    <field name="user_id" invisible="1"/>
                </group>
                <separator string="Available Services - Check What You Need"/>
                <field name="selected_step_ids" widget="many2many_checkboxes" nolabel="1" domain="[('state', '=', 'active')]"/>
                <footer>
                    <button name="action_confirm" string="Confirm Selection" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>