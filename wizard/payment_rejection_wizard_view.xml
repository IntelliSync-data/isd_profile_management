<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Payment Rejection Wizard Form -->
    <record id="view_payment_rejection_wizard_form" model="ir.ui.view">
        <field name="name">payment.rejection.wizard.form</field>
        <field name="model">payment.rejection.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Payment">
                <group>
                    <field name="payment_id" readonly="1"/>
                    <field name="rejection_reason" placeholder="Please provide a clear reason for rejecting this payment..."/>
                </group>
                <footer>
                    <button name="action_reject_payment" string="Reject Payment" type="object" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>